# Supabase
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_API_KEY=
GOOGLE_API_KEY=

# Liveblocks
VITE_LIVEBLOCKS_PUBLIC_KEY=

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_AFTER_SIGN_IN_URL=/dashboard
VITE_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (server-only — never prefix with VITE_)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # from `stripe listen` (dev) or the dashboard endpoint
STRIPE_PRICE_DAY=price_...               # 24h day pass (one-time)
STRIPE_PRICE_MONTH=price_...             # monthly subscription
STRIPE_PRICE_YEAR=price_...              # yearly subscription

# App URL (Stripe redirect base — no trailing slash)
APP_URL=http://localhost:5173

# Adsterra (client-exposed)
VITE_ADSTERRA_BANNER_KEY=                # "Key" of a 468x60 banner unit
VITE_ADSTERRA_POPUNDER_SRC=              # full invoke.js src URL of a popunder unit

# Misc
VITE_N8N_API_URL=
VITE_CLAUDE_API_KEY=
